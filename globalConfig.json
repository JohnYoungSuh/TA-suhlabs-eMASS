{
    "meta": {
        "name": "TA-suhlabs-eMASS",
        "restRoot": "TA_suhlabs_eMASS",
        "displayName": "SuhLabs eMASS Technology Add-on",
        "version": "1.0.4",
        "schemaVersion": "0.0.10"
    },
    "pages": {
        "configuration": {
            "title": "Configuration",
            "description": "Configure eMASS API credentials and connection settings",
            "tabs": [
                {
                    "name": "account",
                    "title": "eMASS Account",
                    "table": {
                        "header": [
                            {
                                "field": "name",
                                "label": "Account Name"
                            },
                            {
                                "field": "system_id",
                                "label": "System ID"
                            },
                            {
                                "field": "base_url",
                                "label": "Base URL"
                            },
                            {
                                "field": "index",
                                "label": "Default Index"
                            }
                        ],
                        "actions": [
                            "edit",
                            "delete",
                            "clone"
                        ]
                    },
                    "entity": [
                        {
                            "field": "name",
                            "label": "Account Name",
                            "type": "text",
                            "help": "Enter a unique name for this eMASS account configuration",
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Account name must be between 1 and 100 characters"
                                },
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Account name must start with a letter and contain only alphanumeric characters and underscores"
                                }
                            ]
                        },
                        {
                            "field": "base_url",
                            "label": "eMASS Base URL",
                            "type": "text",
                            "help": "Base URL for the eMASS API (e.g., http://localhost:4010 or https://emass.mil)",
                            "required": true,
                            "defaultValue": "http://localhost:4010",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 500,
                                    "errorMsg": "Base URL must be between 1 and 500 characters"
                                },
                                {
                                    "type": "regex",
                                    "pattern": "^https?://[^\\s/$.?#].[^\\s]*$",
                                    "errorMsg": "Base URL must be a valid HTTP or HTTPS URL"
                                }
                            ]
                        },
                        {
                            "field": "system_id",
                            "label": "System ID",
                            "type": "text",
                            "help": "eMASS System ID (e.g., 55090). The API endpoint will be constructed as: {base_url}/api/systems/{system_id}/poams",
                            "required": true,
                            "defaultValue": "55090",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 50,
                                    "errorMsg": "System ID must be between 1 and 50 characters"
                                },
                                {
                                    "type": "regex",
                                    "pattern": "^[0-9]+$",
                                    "errorMsg": "System ID must contain only numeric characters"
                                }
                            ]
                        },
                        {
                            "field": "api_key",
                            "label": "API Key",
                            "type": "text",
                            "help": "eMASS API key for authentication (will be encrypted and stored securely)",
                            "required": true,
                            "encrypted": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 8192,
                                    "errorMsg": "API Key must be between 1 and 8192 characters"
                                }
                            ]
                        },
                        {
                            "field": "user_uid",
                            "label": "User UID",
                            "type": "text",
                            "help": "eMASS User UID for authentication (optional, required by some eMASS deployments)",
                            "required": false,
                            "defaultValue": "",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 100,
                                    "errorMsg": "User UID must be between 0 and 100 characters"
                                }
                            ]
                        },
                        {
                            "field": "index",
                            "label": "Default Index",
                            "type": "singleSelect",
                            "help": "Select the Splunk index where POA&M data will be stored. You can select an existing index or type a new name to create one.",
                            "required": true,
                            "defaultValue": "main",
                            "options": {
                                "endpointUrl": "data/indexes",
                                "denyList": "^_.*$",
                                "createSearchChoice": true
                            },
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 80,
                                    "errorMsg": "Index name must be between 1 and 80 characters"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "output",
                    "title": "Output Settings",
                    "table": {
                        "header": [
                            {
                                "field": "name",
                                "label": "Name"
                            },
                            {
                                "field": "http_method",
                                "label": "HTTP Method"
                            },
                            {
                                "field": "endpoint",
                                "label": "Endpoint"
                            }
                        ],
                        "actions": [
                            "edit",
                            "delete",
                            "clone"
                        ]
                    },
                    "entity": [
                        {
                            "field": "name",
                            "label": "Output Name",
                            "type": "text",
                            "help": "Enter a unique name for this output configuration",
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Output name must be between 1 and 100 characters"
                                },
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Output name must start with a letter and contain only alphanumeric characters and underscores"
                                }
                            ]
                        },
                        {
                            "field": "http_method",
                            "label": "HTTP Method",
                            "type": "singleSelect",
                            "help": "Select HTTP method for POAM updates",
                            "required": true,
                            "defaultValue": "POST",
                            "options": {
                                "disableSearch": true,
                                "autoCompleteFields": [
                                    {
                                        "label": "POST - Create new POAM",
                                        "value": "POST"
                                    },
                                    {
                                        "label": "PUT - Update existing POAM",
                                        "value": "PUT"
                                    }
                                ]
                            }
                        },
                        {
                            "field": "endpoint",
                            "label": "API Endpoint",
                            "type": "text",
                            "help": "eMASS API endpoint path (e.g., /api/systems/{system_id}/poams)",
                            "required": true,
                            "defaultValue": "/api/systems/{system_id}/poams",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 500,
                                    "errorMsg": "Endpoint must be between 1 and 500 characters"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "proxy",
                    "title": "Proxy Settings",
                    "type": "proxyTab",
                    "proxy_type": true,
                    "username": true,
                    "password": true,
                    "dns_resolution": true
                },
                {
                    "type": "loggingTab",
                    "label": "Log Level"
                }
            ]
        },
        "inputs": {
            "title": "Inputs",
            "description": "Configure eMASS POA&M data collection inputs",
            "services": [
                {
                    "name": "emass_poam",
                    "title": "eMASS POA&M Collection",
                    "entity": [
                        {
                            "field": "name",
                            "label": "Input Name",
                            "type": "text",
                            "help": "Enter a unique name for this data input",
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Input name must be between 1 and 100 characters"
                                },
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Input name must start with a letter and contain only alphanumeric characters and underscores"
                                }
                            ]
                        },
                        {
                            "field": "account",
                            "label": "eMASS Account",
                            "type": "singleSelect",
                            "help": "Select the eMASS account to use for data collection. The account's default index will be used if configured.",
                            "required": true,
                            "options": {
                                "referenceName": "account"
                            }
                        },
                        {
                            "field": "interval",
                            "label": "Interval",
                            "type": "text",
                            "help": "Collection interval in seconds (e.g., 300 for 5 minutes)",
                            "required": true,
                            "defaultValue": "300",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        31536000
                                    ]
                                }
                            ]
                        },
                        {
                            "field": "index",
                            "label": "Index",
                            "type": "singleSelect",
                            "help": "Select the Splunk index where POA&M data will be stored. If the selected account has a default index configured, it will be used automatically. You can override it by selecting a different index here.",
                            "required": true,
                            "defaultValue": "main",
                            "options": {
                                "endpointUrl": "data/indexes",
                                "denyList": "^_.*$",
                                "createSearchChoice": true
                            },
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 80,
                                    "errorMsg": "Index name must be between 1 and 80 characters"
                                }
                            ]
                        }
                    ]
                }
            ],
            "table": {
                "actions": [
                    "edit",
                    "delete",
                    "clone"
                ],
                "header": [
                    {
                        "label": "Input Name",
                        "field": "name"
                    },
                    {
                        "label": "Account",
                        "field": "account"
                    },
                    {
                        "label": "Interval",
                        "field": "interval"
                    },
                    {
                        "label": "Index",
                        "field": "index"
                    },
                    {
                        "label": "Status",
                        "field": "disabled"
                    }
                ]
            }
        }
    }
}
